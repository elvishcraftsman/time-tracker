{
    "id" : "com.lynnmichaelmartin.TimeTracker",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "command" : "com.lynnmichaelmartin.TimeTracker",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--filesystem=home"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/typescript/bin:/usr/lib/sdk/node24/bin"
    },
    "modules" : [
        {
            "name" : "time-tracker",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "file:///home/lynn/Projects"
                }
            ]
        }
    ]
}
